# Copy to .env.local for local development overrides

# URL for the parcels PMTiles file.
# In dev, served from /data/parcels.pmtiles (not committed — build locally).
# In production, point to your CDN (e.g. Cloudflare R2, GitHub Releases, etc.)
# VITE_PMTILES_URL=https://your-cdn.example.com/parcels.pmtiles
